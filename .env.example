# GeoYard Diagnostics - Environment Variables
# Copy this file to .env.local and fill in your credentials

# Geotab API Configuration (Development Only)
VITE_GEOTAB_SERVER=my.geotab.com
VITE_GEOTAB_DATABASE=your_database
VITE_GEOTAB_USERNAME=your_username
VITE_GEOTAB_PASSWORD=your_password

# Rai backend runs in Firebase Functions.
# Do NOT put secrets in this root file for production.
# Use Firebase Secret Manager:
#   firebase functions:secrets:set RAI_GEMINI_API_KEY
# Non-secret runtime variables can live in functions/.env (see functions/.env.example).
