{
  "name": "geoyard-diagnostics",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stable": "VITE_DISABLE_HMR=1 vite",
    "preview:stable": "vite preview --host 127.0.0.1 --port 5176 --strictPort",
    "serve:stable": "npm run build && npm run preview:stable",
    "build:local": "VITE_ENABLE_DEV_AUTH_SHIM=1 tsc -b && VITE_ENABLE_DEV_AUTH_SHIM=1 vite build",
    "serve:local": "npm run build:local && npm run preview:stable",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "serve:local:stable": "bash ./scripts/serve_local_stable.sh",
    "serve:local:stable:nobuild": "BUILD_ON_START=0 bash ./scripts/serve_local_stable.sh"
  },
  "dependencies": {
    "@geotab/zenith": "^3.4.1",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "@types/react-window": "^1.8.8",
    "chart.js": "^4.5.1",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
    "react-leaflet": "^5.0.0",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^2.2.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^28.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
