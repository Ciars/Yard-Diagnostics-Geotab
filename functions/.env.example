# Firebase Functions runtime variables for Rai (non-secret defaults)
# Copy to functions/.env for local emulator usage if needed.

RAI_GEMINI_MODEL=gemini-3.1-pro-preview
RAI_ALLOWED_ORIGINS=https://your-firebase-project-id.web.app

# Optional guardrails/tuning
# RAI_MAX_REQUEST_BYTES=64000
# RAI_RATE_LIMIT_CAPACITY=8
# RAI_RATE_LIMIT_REFILL_PER_MINUTE=4
# RAI_MAX_GLOBAL_CONCURRENCY=32
# RAI_MAX_PER_SESSION_CONCURRENCY=2
# RAI_CACHE_TTL_SECONDS=45

# Secret is managed via Firebase Secret Manager:
# firebase functions:secrets:set RAI_GEMINI_API_KEY
